APP_NAME=EchoMind API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
FRONTEND_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DATABASE_URL=sqlite:///./data/echomind.db
IMPORT_MAX_FILE_BYTES=26214400
IMPORT_MAX_CONVERSATIONS=500
IMPORT_MAX_PARTICIPANTS=10000
IMPORT_MAX_MESSAGES=50000
IMPORT_MAX_MESSAGE_CHARACTERS=100000
IMPORT_CHUNK_SIZE_BYTES=65536
IMPORT_MAX_METADATA_BYTES=65536
# Stage 6 defaults to the deterministic offline provider.
LLM_PROVIDER=mock
LLM_REMOTE_ENABLED=false
LLM_OPENAI_COMPATIBLE_ENDPOINT=
# Set only in a private .env; never commit a real value.
LLM_OPENAI_COMPATIBLE_API_KEY=
LLM_OPENAI_COMPATIBLE_MODEL=
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_READ_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_VERIFY_TLS=true
LLM_ALLOW_INSECURE_LOCAL_HTTP=false
LLM_MAX_INPUT_CHARACTERS=100000
LLM_MAX_MESSAGES=100
LLM_MAX_MESSAGE_CHARACTERS=20000
LLM_MAX_SCHEMA_CHARACTERS=50000
LLM_MAX_OUTPUT_TOKENS=4096
LLM_MAX_RESPONSE_BYTES=1048576
PROFILE_MAX_INSIGHTS=1000
PROFILE_MAX_EVIDENCE=5000
PROFILE_MAX_JSON_BYTES=5242880
PROFILE_MAX_MARKDOWN_BYTES=5242880
PROFILE_MAX_STATEMENT_CHARACTERS=10000
PROFILE_MAX_REASONING_CHARACTERS=5000
